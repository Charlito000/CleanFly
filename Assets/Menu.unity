--- !u!114 &1066678305
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1066678300}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2469498ee79c25b40aa54b89e7dd3ea3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  panelMenu: {fileID: 75516282}
  panelIntro: {fileID: 1992199901}
  imagenFondo: {fileID: 1380464681}
  textoSubtitulo: {fileID: 267333903}
  tiempoFade: 0.1
  velocidadTexto: 0.05
  sonidoTecleo: {fileID: 0}
  diapositivas:
  - imagen: {fileID: 21300000, guid: 234f858ba8ce1ca4192010f9341ef0b2, type: 3}
    subtitulo: "Desde que era apenas una larvita, supe que hab\xEDa algo diferente
      en m\xED."
    duracionDespuesDeTexto: 2
    audio: {fileID: 8300000, guid: 5acfa394b83a2e34990adb4122da49ea, type: 3}
  - imagen: {fileID: 21300000, guid: 7067f8c96915bb2478e4332826c7db15, type: 3}
    subtitulo: "Mientras las dem\xE1s moscas se peleaban por el basurero m\xE1s apestoso
      del barrio, yo so\xF1aba con pisos brillantes y superficies desinfectadas"
    duracionDespuesDeTexto: 2
    audio: {fileID: 8300000, guid: 262e7c7e33fdee34eb9e030f129b75e1, type: 3}
  - imagen: {fileID: 21300000, guid: 31ae8f46182fb4e448b9b5f69fed7b1f, type: 3}
    subtitulo: "El olor a basura me daba n\xE1useas, y una migaja limpia me parec\xEDa
      un banquete."
    duracionDespuesDeTexto: 2
    audio: {fileID: 8300000, guid: 9479a9f843be0db4aad1b830f809960a, type: 3}
  - imagen: {fileID: 21300000, guid: 992f667cee32e214785a362350aa839d, type: 3}
    subtitulo: "Claro, las otras moscas pensaban que estaba loco. Me llamaban raro,
      exagerado... incluso 'la mosca del jab\xF3n'."
    duracionDespuesDeTexto: 2
    audio: {fileID: 8300000, guid: 6b2df4031d177e745994823b4ed89ca1, type: 3}
  - imagen: {fileID: 21300000, guid: 2eccc1f86751c0b4782cf92c717c6a03, type: 3}
    subtitulo: "Entonces pens\xE9: 'Los humanos s\xED aman la limpieza. Seguro ellos
      me aceptar\xE1n'."
    duracionDespuesDeTexto: 2
    audio: {fileID: 8300000, guid: 65f9a11dc334c324a84376b0595a4dc8, type: 3}
  - imagen: {fileID: 21300000, guid: a75fcf47a44181b4b92fa99abca1b561, type: 3}
    subtitulo: "Qu\xE9 iluso fui. Apenas me acercaba para inspeccionar una cocina
      impecable, sal\xEDan corriendo detr\xE1s de m\xED con un peri\xF3dico, un matamoscas
      o un zapato."
    duracionDespuesDeTexto: 2
    audio: {fileID: 8300000, guid: c671d8275d0cb52448798c099378df4a, type: 3}
  - imagen: {fileID: 21300000, guid: 2eccc1f86751c0b4782cf92c717c6a03, type: 3}
    subtitulo: "Pero ya no busco su aprobaci\xF3n. No importa si me consideran una
      rareza...  Limpiar\xE9 toda la suciedad que encuentre. Polvo, manchas... \xA1Todo
      desaparecer\xE1 bajo mi vigilancia! "
    duracionDespuesDeTexto: 2
    audio: {fileID: 8300000, guid: 38edd8d85254b624093cd55d782536bf, type: 3}
--- !u!1 &1209084776
GameObject:
